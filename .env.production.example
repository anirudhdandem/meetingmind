# ─── Copy to .env.production, fill in, and NEVER commit it. ──────────────────
#
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
#
# APP_ENV=production makes the API refuse to start if anything below is unsafe
# (see _check_production_safety in backend/app/config.py). That's deliberate.

APP_ENV=production
LOG_LEVEL=INFO

# --- Database ---
# Compose builds DATABASE_URL from these and injects it into the api service, so you
# don't set DATABASE_URL here.
POSTGRES_USER=meetingmind
POSTGRES_PASSWORD=CHANGE_ME_long_random_password
POSTGRES_DB=meetingmind

# --- Auth ---
# openssl rand -hex 32
# Encrypts every enrolled TOTP secret. Rotating it forces all users to re-enrol.
# BACK THIS UP WITH THE DATABASE — the two are useless apart.
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32

TOTP_ISSUER=MeetingMind
SESSION_TTL_HOURS=12

# HTTPS only. Refuses to boot if false while APP_ENV=production.
COOKIE_SECURE=true
# "lax" works because app.blostem.com and api.blostem.com share the blostem.com
# registrable domain. Do NOT use "strict" — it would withhold the session cookie on
# Google's OAuth callback redirect and silently break the Google connect flows.
COOKIE_SAMESITE=lax
# Leading dot: the cookie is set by the API host and must be readable across subdomains.
COOKIE_DOMAIN=.blostem.com

# Credentialed CORS forbids "*". List the dashboard's public origin(s), comma-separated.
CORS_ALLOW_ORIGINS=https://app.blostem.com

MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
MAX_MFA_ATTEMPTS=5

# --- Frontend build ---
# Inlined into the browser bundle AT BUILD TIME. Must be the API origin a browser can
# reach — not the compose service name.
NEXT_PUBLIC_API_URL=https://api.blostem.com

# --- Bot (Google Meet) ---
# Headful Chromium on a virtual X display: no window, nothing rendered, Meet none the
# wiser. BOT_HEADLESS must stay false — Meet detects headless, and a headless browser
# produces no PulseAudio stream for audio_capture to record.
USE_XVFB=true
BOT_HEADLESS=false
BOT_DISPLAY_NAME=Notetaker
# The blostem.com Workspace account the bot signs in as. Its email is also what people
# add as a meeting participant so it's auto-admitted.
BOT_GOOGLE_ACCOUNT_EMAIL=notetaker.blostem@blostem.com
BOT_GOOGLE_ACCOUNT_PASSWORD=CHANGE_ME
# Each concurrent bot is roughly one core + ~1-1.5GB RAM, plus ~0.5GB of /dev/shm
# (see shm_size in docker-compose.prod.yml) and ~0.5GB of disk for its profile slot.
# Size to the host: 6 wants ~8 cores / 16GB free. Meetings past the limit are not
# dropped — they stay pending and the next auto-join tick launches them.
MAX_CONCURRENT_BOTS=6

# --- Calendar auto-join (à la Fireflies) ---
# Meetings the bot's email is invited to are joined automatically at start time,
# read from the bot account's own calendar. Needs the bot Google account connected
# in Settings WITH calendar access (reconnect once after deploying this feature).
# A user-connected Google Calendar (Settings -> Google Calendar) is swept too:
# ALL its Meet meetings are joined, invite or not — but an uninvited bot knocks
# and waits in the lobby instead of walking in.
AUTO_JOIN_ENABLED=true
# Poll cadence, how early to enter the room, and how far ahead the schedule looks.
AUTO_JOIN_POLL_SECONDS=60
AUTO_JOIN_LEAD_SECONDS=60
AUTO_JOIN_LOOKAHEAD_HOURS=12
# A bot alone in a meeting (no-show, or everyone left) leaves after this long,
# freeing its slot. 0 = never leave on its own (pre-auto-join behaviour).
BOT_ALONE_TIMEOUT_SECONDS=600
# How long the bot knocks before giving up on a meeting nobody admits it to
# (cancelled meeting / no-show). Mainly applies to uninvited calendar joins.
BOT_ADMIT_TIMEOUT_SECONDS=300

# --- Team / role attribution ---
# Any attendee on these domains is our team; everyone else is the client.
INTERNAL_EMAIL_DOMAINS=blostem.com
OUR_COMPANY_NAME=Blostem

# --- LiveKit Cloud ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Deepgram (STT) ---
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=multi

# --- Gemini (LLM + embeddings) ---
# Pick ONE auth path:
#   Vertex AI (what prod uses) — set the project below and put the service-account JSON
#   at ./secrets/vertex-sa.json on the host. docker-compose.prod.yml mounts it read-only
#   and pins GEMINI_VERTEX_CREDENTIALS_FILE to the in-container path, so leave it unset
#   here. The key never enters git or the image; rotating it is a file swap + restart.
GEMINI_VERTEX_PROJECT=blostem-vox-vertex
GEMINI_VERTEX_LOCATION=us-central1
#   AI Studio — a plain key instead. Leave GEMINI_VERTEX_PROJECT empty to use this.
GEMINI_API_KEY=
GEMINI_LLM_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# --- Google OAuth (participant identity + calendar) ---
# Redirect URI must be registered on the OAuth client exactly as written.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.blostem.com/oauth/google/callback
APP_BASE_URL=https://app.blostem.com

# --- Google Meet REST API (optional: post-meeting transcript import) ---
# GOOGLE_SERVICE_ACCOUNT_FILE=
# GOOGLE_IMPERSONATE_SUBJECT=
